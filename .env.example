# KCPC 환경 설정 예시
# 이 파일을 .env로 복사한 후 필요에 따라 수정하세요

# ============================================
# DuckDuckGo 요청 설정
# ============================================
DDG_MIN_DELAY=2.0
DDG_MAX_DELAY=3.5
DDG_MAX_RETRIES=3
DDG_TIMEOUT=10
DDG_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
DDG_MAX_RESULTS=10

# ============================================
# 차단 우회 옵션 (사용자 명시적 설정 시에만 활성화)
# ============================================
# 프록시 사용 (proxies.txt 필요)
DDG_USE_PROXY=false
DDG_PROXY_LIST=./proxies.txt

# User-Agent 순환 (user_agents.txt 필요)
DDG_ROTATE_UA=false
DDG_UA_LIST=./user_agents.txt

# 딜레이 무시 (차단 위험 높음)
DDG_IGNORE_DELAY=false

# SSL 검증 우회
DDG_IGNORE_SSL=false

# ============================================
# QA 자동 테스트 설정 (v2.0)
# ============================================
# 자동 테스트 단어 생성 활성화
QA_AUTO_GENERATE_WORDS=true
# 생성할 단어 수
QA_WORD_COUNT=10
# 무한 반복 QA 활성화
QA_RETRY_UNTIL_PASS=true
# 최대 재시도 간격 (초)
QA_MAX_RETRY_INTERVAL=60
# 빈도별 단어 수 (고:중:저)
QA_HIGH_FREQ_WORDS=3
QA_MID_FREQ_WORDS=4
QA_LOW_FREQ_WORDS=3
# DDG 백엔드 교차 검증 활성화
DDG_CROSS_VALIDATE=true
# 재현성 검증 반복 횟수
DDG_REPRODUCIBILITY_TRIALS=3
# DDG 백엔드 교차 검증 허용 편차
DDG_BACKEND_VARIANCE_TOLERANCE=1

# ============================================
# 데이터베이스 및 출력 경로
# ============================================
DB_FILE_PATH=./data/kcpc_database.db
LOG_FILE_PATH=./logs/kcpc.log
OUTPUT_FILE_PATH=./output/kcpc_result.xlsx
OUTPUT_FORMAT=xlsx
